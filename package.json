{
  "name": "real-time-analytics-system",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end real-time analytics pipeline: Express + BullMQ + Postgres + Redis + Socket.io + React",
  "type": "commonjs",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:worker": "node server/worker.js",
    "dev:client": "npm --workspace client run dev",
    "simulate": "node scripts/simulate.js",
    "db:init": "node server/init-db.js",
    "install:all": "npm install && npm --workspace client install"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
